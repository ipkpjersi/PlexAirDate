{
  "manifest_version": 3,
  "name": "Plex Air Date",
  "version": "0.4.0",
  "description": "Adds episode air dates and a rating to Plex show, season, and episode pages, showing the current, latest, and next episode air dates, when a season aired, plus the MAL score for anime and the IMDb rating for everything else.",
  "browser_specific_settings": {
    "gecko": {
      "id": "plex-air-date@example.com",
      "strict_min_version": "142.0",
            "data_collection_permissions": {
            "required": [
              "websiteContent"
            ]
          }
    }
  },
  "permissions": [],
  "host_permissions": [
    "https://api.tvmaze.com/*",
    "https://graphql.anilist.co/*",
    "https://api.jikan.moe/*",
    "https://www.omdbapi.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
