{
  "manifest_version": 3,
  "name": "Plex Air Date",
  "version": "0.2.0",
  "description": "Adds episode air dates to Plex show and episode pages, showing when the current episode aired and when the next episode airs.",
  "permissions": [],
  "host_permissions": [
    "https://api.tvmaze.com/*",
    "https://graphql.anilist.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
